{
  "design_name": "converter_attached_neural_amp",
  "work_dir": "run",
  "include_files": [],
  "library_sections": [
    {
      "path": "/home/eda/edk_cadence/sky130_release_0.1.0/models/sky130.lib.spice",
      "section": "tt"
    }
  ],
  "ahdl_include_files": [],
  "top_netlist": "converter_example_top.scs",
  "top_subckt": "TOP",
  "pin_mapping_wrapper": {
    "enabled": false,
    "raw_netlist": "student_raw_netlist.scs",
    "core": {
      "subckt": "MY_AMP",
      "pin_order": ["GND", "VDD", "INP", "OUT", "REF"],
      "pin_map": {
        "INP": "VIN",
        "REF": "VREF",
        "OUT": "VOUT"
      }
    },
    "converter": {
      "subckt": "MY_CONV",
      "pin_order": ["OUTP", "GND", "INN", "INP"],
      "pin_map": {
        "OUTP": "VDD",
        "INN": "VAC_N",
        "INP": "VAC_P"
      }
    }
  },
  "spec": {
    "vdd": 5.0,
    "vref_ratio": 0.5,
    "vindc_ratio": 0.5,
    "input_ac_amplitude": 0.001,
    "midband_gain_vv": 100.0,
    "low_cut_hz": 10.0,
    "high_cut_hz": 20000.0,
    "rolloff_order_each_side": 4,
    "load_cap_f": 1e-11,
    "attenuation_probe_low_hz": 1.0,
    "attenuation_probe_high_hz": 200000.0
  },
  "converter_input": {
    "kind": "sine",
    "dc_v": 0.0,
    "amplitude_v": 3.0,
    "frequency_hz": 100000.0,
    "file": ""
  },
  "initial_conditions": {
    "enabled": true,
    "vdd_raw_v": 5.0,
    "vdd_core_v": 5.0,
    "vout_v": 2.5,
    "skipdc": false
  },
  "power": {
    "steady_start_s": 0.004
  },
  "sim": {
    "spectre_cmd": "spectre",
    "spectre_args": ["+lqtimeout", "60"],
    "ocean_cmd": "ocean",
    "run_spectre": true,
    "run_ocean_export": true,
    "ac": {
      "start_hz": 0.1,
      "stop_hz": 10000000.0,
      "points_per_dec": 50
    },
    "tran": {
      "stop_s": 0.02,
      "maxstep_s": 1e-6,
      "strobe_s": 2e-6,
      "input": {
        "kind": "sine",
        "amplitude_v": 0.001,
        "frequency_hz": 1000.0
      },
      "settle_skip_s": 0.004,
      "fft_fundamental_hz": 1000.0
    }
  },
  "input_files": {
    "devices_core_csv": "devices_core.csv",
    "ac_csv": "run/ac.csv",
    "static_tran_csv": "run/tran_core_static.csv",
    "tran_csv": "run/tran_core.csv"
  }
